{
    "name": "@rnw-community/decorators-core",
    "version": "2.0.2",
    "description": "Framework-agnostic interceptor primitive for building method decorators (Log, metrics, lock, retry, ...). Pure middleware composition. Dual ESM+CJS. Built on TypeScript's experimentalDecorators.",
    "keywords": [
        "decorator",
        "decorators",
        "interceptor",
        "middleware",
        "method decorator",
        "aspect",
        "universal",
        "framework-agnostic"
    ],
    "repository": "https://github.com/rnw-community/rnw-community/tree/master/packages/decorators-core",
    "license": "MIT",
    "exports": {
        ".": {
            "types": "./dist/esm/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "main": "dist/cjs/index.js",
    "module": "dist/esm/index.js",
    "types": "dist/esm/index.d.ts",
    "files": [
        "dist/**/*"
    ],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "ts": "run -T tsc --pretty -p tsconfig.json",
        "build:esm": "run -T tsc --pretty -p tsconfig.build-esm.json",
        "build:cjs": "run -T tsc --pretty -p tsconfig.build-cjs.json",
        "build": "yarn build:esm && yarn build:cjs && rm -rf ./dist/*/*.tsbuildinfo",
        "lint": "run -T eslint src",
        "lint:fix": "run -T eslint --fix src",
        "test": "run -T jest",
        "test:coverage": "run -T jest --coverage",
        "format": "run -T prettier --write \"./src/**/*.{ts,tsx}\"",
        "clear": "rm -rf coverage && rm -rf dist && rm -f *.tsbuildinfo",
        "clear:deps": "rm -rf ./node_modules && rm -rf ./dist"
    },
    "dependencies": {
        "@rnw-community/shared": "workspace:^"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "rxjs": "^7.8.2"
    },
    "peerDependencies": {
        "rxjs": "^7.8.0",
        "typescript": ">=5.2.0"
    },
    "peerDependenciesMeta": {
        "rxjs": {
            "optional": true
        },
        "typescript": {
            "optional": true
        }
    }
}
