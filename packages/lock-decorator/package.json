{
    "name": "@rnw-community/lock-decorator",
    "version": "0.1.0",
    "description": "Framework-agnostic sequential and exclusive method lock decorators. Dual ESM+CJS. Legacy (experimentalDecorators) + TC39 stage-3.",
    "keywords": [
        "decorator",
        "lock",
        "mutex",
        "sequential",
        "exclusive",
        "method decorator",
        "stage-3",
        "tc39",
        "framework-agnostic"
    ],
    "repository": "https://github.com/rnw-community/rnw-community/tree/master/packages/lock-decorator",
    "license": "MIT",
    "exports": {
        ".": {
            "types": "./dist/esm/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        },
        "./rxjs": {
            "types": "./dist/esm/rxjs/index.d.ts",
            "import": "./dist/esm/rxjs/index.js",
            "require": "./dist/cjs/rxjs/index.js"
        }
    },
    "main": "dist/cjs/index.js",
    "module": "dist/esm/index.js",
    "types": "dist/esm/index.d.ts",
    "typesVersions": {
        "*": {
            "rxjs": [
                "./dist/esm/rxjs/index.d.ts"
            ]
        }
    },
    "files": [
        "dist/**/*"
    ],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "ts": "run -T tsc --pretty -p tsconfig.json",
        "build:esm": "run -T tsc --pretty -p tsconfig.build-esm.json",
        "build:cjs": "run -T tsc --pretty -p tsconfig.build-cjs.json",
        "build": "yarn build:esm && yarn build:cjs && rm -rf ./dist/*/*.tsbuildinfo",
        "lint": "run -T eslint src",
        "lint:fix": "run -T eslint --fix src",
        "test": "run -T jest",
        "test:coverage": "run -T jest --coverage",
        "format": "run -T prettier --write \"./src/**/*.{ts,tsx}\"",
        "clear": "rm -rf coverage && rm -rf dist && rm -f *.tsbuildinfo",
        "clear:deps": "rm -rf ./node_modules && rm -rf ./dist"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "@rnw-community/decorators-core": "workspace:^",
        "@rnw-community/shared": "workspace:^"
    },
    "devDependencies": {
        "rxjs": "^7.8.2"
    },
    "peerDependencies": {
        "rxjs": "^7.8.0",
        "typescript": ">=5.0.0"
    },
    "peerDependenciesMeta": {
        "rxjs": {
            "optional": true
        },
        "typescript": {
            "optional": true
        }
    }
}
